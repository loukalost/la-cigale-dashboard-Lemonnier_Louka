# La Cigale CRM - Backend Environment Configuration
# 
# IMPORTANT SECURITY NOTES:
# 1. Copy this file to .env (local dev only)
# 2. NEVER commit .env file to git
# 3. For production, use Render Environment Variables dashboard
#    https://docs.render.com/environment-variables
# 4. Rotate AIRTABLE_API_KEY every 6 months (security best practice)

# ==================== AIRTABLE CONFIGURATION ====================
# 
# How to get these values:
# - AIRTABLE_API_KEY  : https://airtable.com/account/my-api-tokens
#   * Click "Generate new token" 
#   * Scopes: data.records:read, data.records:write, data.records:destroy
#   * Paste the sk_live/sk_test token here (do NOT commit!)
#
# - AIRTABLE_BASE_ID  : From your base URL
#   * Example: https://airtable.com/appXXXXXXXXXXXXXX/...
#   * Copy the appXXXXXXXXXXXXXX part
#
# Required for production deployment!
AIRTABLE_API_KEY=sk_test_xxx_REPLACE_WITH_YOUR_TOKEN_xxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Réservations

# ==================== SERVER CONFIGURATION ====================
#
# PORT: Which port backend listens on (default 5000)
# NODE_ENV: development | production (affects logging, error handling)
PORT=5000
NODE_ENV=development

# ==================== CORS CONFIGURATION ====================
#
# CORS_ORIGIN: Which frontend origin can call this backend
# 
# Local development:  http://localhost:3000
# Production/Render:  https://crm-la-cigale.render.com (or your custom domain)
#
# Security: Only listed origin can make requests. Prevents CSRF attacks.
CORS_ORIGIN=http://localhost:3000

# Example production configuration (uncomment for prod deploy):
# CORS_ORIGIN=https://crm-la-cigale.render.com
# NODE_ENV=production
# AIRTABLE_API_KEY=sk_live_prod_token_from_render_secrets

