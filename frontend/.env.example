# La Cigale CRM - Frontend Environment Configuration
#
# IMPORTANT SECURITY NOTES:
# 1. Copy this file to .env (local dev only)
# 2. NEVER commit .env file to git
# 3. Frontend should NEVER contain API keys (Airtable token is backend-only)
# 4. For production, use Render static site environment variables

# ==================== API SERVER ====================
#
# VITE_API_URL: Where frontend sends API requests
# 
# Local development:  http://localhost:5000/api
# Production/Render:  https://crm-la-cigale.render.com/api
#
# Vite build strips all VITE_* vars not used in code (security feature)
# Access in code: import.meta.env.VITE_API_URL
VITE_API_URL=http://localhost:5000/api

# ==================== DEBUGGING ====================
#
# Optional: Enable debug logging (not needed for V0)
VITE_DEBUG=false

# Example production configuration (uncomment for prod deploy):
# VITE_API_URL=https://crm-la-cigale.render.com/api

